# # npm 配置文件
# # 依赖存储路径
# prefix=D:/soft/nodejs/node_global/npm

# # 缓存路径
# cache=D:/soft/nodejs/node_cache/npm

# # 注册表设置（使用国内镜像加速）
# registry=https://registry.npmmirror.com

# # 严格安装模式（确保依赖版本一致性）
# strict-peer-dependencies=true

# # 跳过可选依赖
# optional=false

# # 保存依赖时自动更新 package.json
# save=true

# # 扁平化依赖树（减少依赖嵌套）
# depth=0

# # 日志级别
# loglevel=info

# # 超时设置（毫秒）
# timeout=300000

# # 最大并行下载数
# maxsockets=5

# # 禁用自动安装
# ignore-scripts=false

# # 代理设置（如果需要）
# # proxy=http://proxy.example.com:8080
# # https-proxy=http://proxy.example.com:8080
# # no-proxy=localhost,127.0.0.1